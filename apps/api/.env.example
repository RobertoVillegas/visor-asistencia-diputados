PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gaceta_attendance
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAILS=roberto@athas.mx
LOG_LEVEL=info
CRON_ENABLED=true
CRON_HOUR=3
# Optional override. Leave empty so the cron always picks the latest legislature
# discovered on gaceta.diputados.gob.mx.
CRON_TARGET_LEGISLATURE=
JOB_POLL_INTERVAL_MS=5000
# Optional. Used by scripts/verify-with-firecrawl.ts to cross-check the parser.
FIRECRAWL_API_KEY=