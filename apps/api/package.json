{
  "name": "@workspace/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "verify:parser": "bun scripts/verify-attendance-parser.ts",
    "verify:absence": "bun scripts/verify-absence-parser.ts",
    "verify:firecrawl": "bun scripts/verify-with-firecrawl.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "bunx @better-auth/cli generate --config src/lib/auth.ts --output src/db/schema/better-auth.ts --yes"
  },
  "dependencies": {
    "better-auth": "^1.3.7",
    "cheerio": "^1.1.2",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.10.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.7",
    "unpdf": "^1.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.7",
    "@types/bun": "^1.3.1",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3"
  }
}
